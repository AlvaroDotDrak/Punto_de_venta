# Punto de Venta – Pastelería · Variables de entorno
# Copiar este archivo a .env y completar con valores reales antes de iniciar.

# Salt para el hashing SHA-256 de PINs.
# ⚠️  Cambiar este valor invalida TODOS los PINs existentes.
PIN_SALT=cambiar_por_valor_secreto

# Clave secreta para firmar los JWT (Bearer tokens).
# Debe ser una cadena larga y aleatoria. Ejemplo: openssl rand -hex 32
JWT_SECRET_KEY=cambiar_por_valor_secreto
